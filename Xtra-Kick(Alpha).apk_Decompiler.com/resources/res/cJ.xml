<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/scrollView" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:layout_marginBottom="7dp" android:layout_marginStart="10dp" android:layout_marginEnd="10dp">
        <TextView android:gravity="start" android:id="@+id/userCount" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:textAlignment="viewStart"/>
        <TextView android:gravity="start" android:id="@+id/broadcasterText" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/broadcaster" android:textAlignment="viewStart" style="@style/VideoTitle"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/broadcasterList" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <TextView android:gravity="start" android:id="@+id/moderatorsText" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/moderators" android:textAlignment="viewStart" style="@style/VideoTitle"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/moderatorsList" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <TextView android:gravity="start" android:id="@+id/vipsText" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/vips" android:textAlignment="viewStart" style="@style/VideoTitle"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/vipsList" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <TextView android:gravity="start" android:id="@+id/viewersText" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/viewers" android:textAlignment="viewStart" style="@style/VideoTitle"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/viewersList" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
