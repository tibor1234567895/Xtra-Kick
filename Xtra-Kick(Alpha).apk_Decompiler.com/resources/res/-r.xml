<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:animateLayoutChanges="true">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerView" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <Button android:layout_gravity="bottom" android:id="@+id/btnDown" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/scroll_down"/>
        </FrameLayout>
        <LinearLayout android:orientation="horizontal" android:id="@+id/messageView" android:background="?attr/primaryColor" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:animateLayoutChanges="true" app:layout_constraintBottom_toTopOf="@+id/emoteMenu">
            <MultiAutoCompleteTextView android:id="@+id/editText" android:layout_width="0dp" android:layout_height="match_parent" android:completionThreshold="1" android:layout_weight="1" android:inputType="none|text|textCapSentences|textAutoCorrect" android:imeOptions="actionUnspecified|actionSend|flagNoFullscreen" android:importantForAutofill="2"/>
            <ImageButton android:id="@+id/clear" android:background="?android:attr/selectableItemBackground" android:visibility="gone" android:layout_width="50dp" android:layout_height="match_parent" android:src="@drawable/baseline_backspace_black_24" app:tint="?attr/textColor"/>
            <ImageButton android:id="@+id/emotes" android:background="?android:attr/selectableItemBackground" android:layout_width="50dp" android:layout_height="match_parent" android:src="@drawable/ic_tag_faces_black_24dp" app:tint="?attr/textColor"/>
            <ImageButton android:id="@+id/send" android:background="?android:attr/selectableItemBackground" android:visibility="gone" android:layout_width="50dp" android:layout_height="match_parent" android:src="@drawable/ic_send_black_24dp" app:tint="?attr/textColor"/>
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:id="@+id/emoteMenu" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintBottom_toBottomOf="0">
            <com.google.android.material.tabs.TabLayout android:id="@+id/tabLayout" android:layout_width="match_parent" android:layout_height="wrap_content" app:tabGravity="0" app:tabMaxWidth="0dp" app:tabMode="1"/>
            <androidx.viewpager2.widget.ViewPager2 android:id="@+id/viewPager" android:layout_width="match_parent" android:layout_height="300dp"/>
        </LinearLayout>
    </LinearLayout>
    <TextView android:textColor="?attr/textColor" android:id="@+id/chatReplayUnavailable" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chat_replay_unavailable" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0"/>
    <com.google.android.flexbox.FlexboxLayout android:id="@+id/flexbox" android:background="?attr/chatStatus" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" app:flexWrap="1" app:justifyContent="5" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0">
        <TextView android:id="@+id/textEmote" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/room_emote" android:maxLines="1"/>
        <TextView android:id="@+id/textFollowers" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1"/>
        <TextView android:id="@+id/textUnique" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/room_unique" android:maxLines="1"/>
        <TextView android:id="@+id/textSlow" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1"/>
        <TextView android:id="@+id/textSubs" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/room_subs" android:maxLines="1"/>
    </com.google.android.flexbox.FlexboxLayout>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/raidLayout" android:background="?attr/chatStatus" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/flexbox">
        <ImageView android:id="@+id/raidImage" android:visibility="gone" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="10dp" android:layout_marginBottom="10dp" android:layout_marginStart="8dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" app:layout_constraintVertical_bias="0"/>
        <TextView android:textSize="16sp" android:layout_gravity="center_vertical" android:id="@+id/raidText" android:visibility="gone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="5dp" android:layout_marginStart="8dp" android:layout_marginEnd="4dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toStartOf="@+id/raidClose" app:layout_constraintStart_toEndOf="@+id/raidImage" app:layout_constraintTop_toTopOf="0"/>
        <ImageView android:id="@+id/raidClose" android:visibility="gone" android:layout_width="20dp" android:layout_height="20dp" android:layout_margin="4dp" android:src="@drawable/baseline_close_black_36" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" app:tint="?attr/textColor"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
