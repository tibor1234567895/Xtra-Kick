<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:padding="5dp" android:layout_width="match_parent" android:layout_height="match_parent">
        <RadioGroup android:id="@+id/sort" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/sort" android:layout_marginStart="5dp"/>
            <RadioButton android:id="@+id/time" android:text="@string/upload_date" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/views" android:text="@string/view_count" style="@style/RadioButton"/>
        </RadioGroup>
        <RadioGroup android:id="@+id/sortType" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/type" android:layout_marginStart="5dp"/>
            <RadioButton android:id="@+id/typeArchive" android:text="@string/video_type_archive" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/typeHighlight" android:text="@string/video_type_highlight" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/typeUpload" android:text="@string/video_type_upload" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/typeAll" android:text="@string/all" style="@style/RadioButton"/>
        </RadioGroup>
        <RadioGroup android:id="@+id/period" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/period" android:layout_marginStart="5dp"/>
            <RadioButton android:id="@+id/today" android:text="@string/today" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/week" android:text="@string/this_week" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/month" android:text="@string/this_month" style="@style/RadioButton"/>
            <RadioButton android:id="@+id/all" android:text="@string/all_time" style="@style/RadioButton"/>
        </RadioGroup>
        <CheckBox android:id="@+id/saveDefault" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/save_default"/>
        <CheckBox android:id="@+id/saveSort" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/apply" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/apply"/>
        <Button android:id="@+id/selectLang" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/select_language"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
