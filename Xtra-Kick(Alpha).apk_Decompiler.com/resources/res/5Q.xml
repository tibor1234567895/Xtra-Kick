<?xml version="1.0" encoding="utf-8"?>
<com.github.andreyasadchy.xtra.ui.view.SlidingLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:id="@+id/slidingLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:layoutDirection="ltr">
    <androidx.media3.ui.AspectRatioFrameLayout android:id="@+id/aspectRatioFrameLayout" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <com.github.andreyasadchy.xtra.ui.view.CustomPlayerView android:id="@+id/playerView" app:controller_layout_id="@layout/player_video" style="@style/Player"/>
    </androidx.media3.ui.AspectRatioFrameLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/clipChatContainer" android:background="?android:attr/colorBackground" android:layout_width="0dp" android:layout_height="0dp">
        <FrameLayout android:id="@+id/chatFragmentContainer" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginBottom="3dp" android:layout_weight="1" style="@style/ChatView"/>
        <Button android:layout_gravity="center" android:id="@+id/watchVideo" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/watch_video" android:textAllCaps="true"/>
    </LinearLayout>
</com.github.andreyasadchy.xtra.ui.view.SlidingLayout>
