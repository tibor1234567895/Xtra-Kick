<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" style="@style/Card">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/topLayout" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="0">
            <ImageView android:id="@+id/thumbnail" android:visibility="gone" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toTopOf="0" style="@style/Thumbnail"/>
            <com.github.andreyasadchy.xtra.util.TextWithCanvas android:id="@+id/viewers" android:visibility="gone" android:layout_marginBottom="5dp" android:layout_marginStart="5dp" app:layout_constraintBottom_toBottomOf="@+id/thumbnail" app:layout_constraintStart_toStartOf="0" style="@style/ThumbnailItem"/>
            <com.github.andreyasadchy.xtra.util.TextWithCanvas android:id="@+id/type" android:visibility="gone" android:layout_marginTop="10dp" android:layout_marginEnd="10dp" app:layout_constraintEnd_toEndOf="0" app:layout_constraintTop_toTopOf="0" style="@style/ThumbnailItem"/>
            <com.github.andreyasadchy.xtra.util.TextWithCanvas android:id="@+id/uptime" android:visibility="gone" android:layout_marginBottom="5dp" android:layout_marginEnd="5dp" app:layout_constraintBottom_toBottomOf="@+id/thumbnail" app:layout_constraintEnd_toEndOf="0" style="@style/ThumbnailItem"/>
            <ImageView android:id="@+id/userImage" android:visibility="gone" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" android:layout_marginStart="10dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/thumbnail" app:layout_constraintVertical_bias="0" style="@style/UserPicture"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="vertical" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginTop="7dp" android:layout_marginBottom="7dp" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:layout_marginEnd="10dp" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toEndOf="@+id/userImage" app:layout_constraintTop_toBottomOf="@+id/thumbnail">
                <TextView android:gravity="start" android:id="@+id/title" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:textAlignment="viewStart" style="@style/VideoTitle"/>
                <TextView android:textColor="?attr/secondaryTextColor" android:gravity="start" android:id="@+id/username" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:textAlignment="viewStart"/>
                <TextView android:textColor="?attr/secondaryTextColor" android:gravity="start" android:id="@+id/gameName" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:textAlignment="viewStart"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.google.android.flexbox.FlexboxLayout android:id="@+id/tagsLayout" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:layout_marginBottom="7dp" android:layout_marginStart="10dp" android:layout_marginEnd="10dp" app:flexWrap="1" app:justifyContent="4" app:layout_constraintBottom_toBottomOf="0" app:layout_constraintEnd_toEndOf="0" app:layout_constraintStart_toStartOf="0" app:layout_constraintTop_toBottomOf="@+id/topLayout"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
