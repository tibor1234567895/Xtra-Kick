<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <View style="@style/PlayerShadow"/>
    <ImageButton style="@style/PlayerPlayPause"/>
    <FrameLayout android:addStatesFromChildren="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="50dp">
        <Button android:background="@drawable/exo_styled_controls_rewind" style="@style/PlayerRewind"/>
    </FrameLayout>
    <FrameLayout android:addStatesFromChildren="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginEnd="50dp" android:layout_alignParentEnd="true">
        <Button android:background="@drawable/exo_styled_controls_fastforward" style="@style/PlayerForward"/>
    </FrameLayout>
    <LinearLayout style="@style/PlayerTopLeftPanel">
        <ImageButton android:layout_marginEnd="5dp" style="@style/PlayerMinimize"/>
        <LinearLayout style="@style/PlayerTopLeftChannelSubPanel">
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerChannel"/>
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerTitle"/>
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerCategory"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout style="@style/PlayerTopRightPanel">
        <ImageButton style="@style/PlayerDownload"/>
        <ImageButton style="@style/PlayerFollow"/>
        <ImageButton style="@style/PlayerSleep"/>
        <ImageButton style="@style/PlayerRatio"/>
        <ImageButton style="@style/PlayerSpeed"/>
        <ImageButton style="@style/PlayerSettings"/>
        <ImageButton style="@style/PlayerMenu"/>
    </LinearLayout>
    <LinearLayout android:layout_above="@+id/exo_progress" android:layout_alignParentBottom="false" style="@style/PlayerBotLeftPanel">
        <ImageButton style="@style/PlayerGames"/>
        <ImageButton style="@style/PlayerVolume"/>
        <ImageButton style="@style/PlayerAudioCompressor"/>
        <ImageButton style="@style/PlayerMode"/>
    </LinearLayout>
    <TextView style="@style/PlayerPosition"/>
    <androidx.media3.ui.DefaultTimeBar android:id="@+id/exo_progress" style="@style/PlayerProgress"/>
    <TextView style="@style/PlayerDuration"/>
    <LinearLayout android:layout_above="@+id/exo_progress" android:layout_alignParentBottom="false" style="@style/PlayerBotRightPanel">
        <ImageButton style="@style/PlayerSubtitleToggle"/>
        <ImageButton style="@style/PlayerChatToggle"/>
        <ImageButton style="@style/PlayerFullscreenToggle"/>
    </LinearLayout>
</RelativeLayout>
