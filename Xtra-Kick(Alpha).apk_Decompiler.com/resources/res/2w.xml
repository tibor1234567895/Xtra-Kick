<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:aapt="http://schemas.android.com/aapt" android:layout_width="match_parent" android:layout_height="match_parent">
    <View style="@style/PlayerShadow"/>
    <ImageButton style="@style/PlayerPlayPause"/>
    <LinearLayout style="@style/PlayerTopLeftPanel">
        <ImageButton android:layout_marginEnd="5dp" style="@style/PlayerMinimize"/>
        <LinearLayout style="@style/PlayerTopLeftChannelSubPanel">
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerChannel"/>
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerTitle"/>
            <TextView android:layout_marginBottom="1dp" style="@style/PlayerCategory"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout style="@style/PlayerTopRightPanel">
        <ImageButton style="@style/PlayerFollow"/>
        <ImageButton style="@style/PlayerSleep"/>
        <ImageButton style="@style/PlayerRatio"/>
        <ImageButton style="@style/PlayerSettings"/>
        <ImageButton style="@style/PlayerMenu"/>
    </LinearLayout>
    <LinearLayout style="@style/PlayerBotLeftPanel">
        <ImageButton style="@style/PlayerRestart"/>
        <ImageButton style="@style/PlayerSeekLive"/>
        <ImageButton style="@style/PlayerVolume"/>
        <ImageButton style="@style/PlayerAudioCompressor"/>
        <ImageButton style="@style/PlayerMode"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/viewersLayout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true">
        <ImageView android:id="@+id/viewerIcon" android:layout_marginBottom="10dp" android:layout_marginEnd="2dp" style="@style/PlayerViewers"/>
        <TextView android:id="@+id/viewers" android:layout_marginTop="6dp" android:layout_marginBottom="15dp" style="@style/PlayerText"/>
    </LinearLayout>
    <LinearLayout style="@style/PlayerBotRightPanel">
        <ImageButton style="@style/PlayerSubtitleToggle"/>
        <ImageButton style="@style/PlayerChatBarToggle"/>
        <ImageButton style="@style/PlayerChatToggle"/>
        <ImageButton style="@style/PlayerFullscreenToggle"/>
    </LinearLayout>
</RelativeLayout>
